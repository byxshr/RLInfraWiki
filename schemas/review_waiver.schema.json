{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "P2",
        "P3"
      ]
    },
    "status": {
      "enum": [
        "requested",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "id",
    "issue_id",
    "status",
    "approved_by",
    "reason"
  ]
}
