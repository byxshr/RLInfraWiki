{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "status": {
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "fixed",
        "closed",
        "waived",
        "backlog"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "round_id",
    "severity",
    "status",
    "summary"
  ]
}
