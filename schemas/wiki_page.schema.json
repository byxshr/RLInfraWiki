{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "backends": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "algorithms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deployment_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "enum": [
        "verified",
        "source-reported",
        "inferred",
        "experimental"
      ]
    },
    "reproducibility": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "version_sensitive": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "local_evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "hardware": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "log": {
          "type": "string",
          "minLength": 1
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "confidence": {
            "const": "verified"
          }
        },
        "required": [
          "confidence"
        ]
      },
      "then": {
        "required": [
          "local_evidence"
        ],
        "properties": {
          "local_evidence": {
            "required": [
              "command",
              "commit",
              "result"
            ],
            "allOf": [
              {
                "anyOf": [
                  {
                    "required": [
                      "hardware"
                    ]
                  },
                  {
                    "required": [
                      "context"
                    ]
                  }
                ]
              },
              {
                "anyOf": [
                  {
                    "required": [
                      "log"
                    ]
                  },
                  {
                    "required": [
                      "artifact_path"
                    ]
                  }
                ]
              }
            ]
          }
        }
      }
    }
  ],
  "required": [
    "id",
    "title",
    "type",
    "confidence",
    "reproducibility",
    "sources",
    "summary",
    "updated_at"
  ]
}
