{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "source_category": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "local_path": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "minLength": 1
    },
    "upstream_ref": {
      "type": "string",
      "minLength": 1
    },
    "upstream_commit": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "trust_level": {
      "type": "string",
      "minLength": 1
    },
    "refresh_policy": {
      "type": "string",
      "minLength": 1
    },
    "relevance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "key_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "id",
    "name",
    "source_category",
    "status",
    "trust_level",
    "captured_at"
  ]
}
