{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "active",
        "completed",
        "blocked",
        "needs-amendment"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "timestamp",
    "status",
    "reason"
  ]
}
